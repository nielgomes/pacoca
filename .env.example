# ========================================
# Configuração do Paçoca - Exemplo
# Copie este arquivo para .env e configure
# ========================================

# ========================================
# OpenRouter API (LLM Principal)
# ========================================
OPENROUTER_API_KEY=sua-chave-openrouter-aqui

# ========================================
# Google Gemini API (Multimodal)
# ========================================
GEMINI_API_KEY=sua-chave-gemini-aqui

# ========================================
# Giphy API (GIFs)
# ========================================
GIPHY_API_KEY=sua-chave-giphy-aqui

# ========================================
# Configurações Adicionais (Opcional)
# ========================================
# NODE_ENV=production
# APP_URL=https://github.com/seu-usuario/pacoca
# APP_NAME=Paçoca
